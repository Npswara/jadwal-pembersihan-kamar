# Salin ke .env — dari Firebase Console > Project settings > Your apps (Web)
# Hanya Firestore Database (tanpa Cloud Storage).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Opsional (boleh dikosongkan jika tidak pakai Storage):
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
